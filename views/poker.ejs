<% include header %>
<style>
#gameDiv {
    margin-top: 20px;
}
.playingCard_black, .playingCard_red, .playingCard_black_opponent, .playingCard_red_opponent {
    display: inline-block;
    width: 60px;
    height: 90px;
    border: 1px solid #ccc;
    border-radius: 5px;
    margin: 5px;
    padding: 10px;
    font-size: 1.2em;
    font-weight: bold;
    text-align: center;
    background-color: white;
    box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
}
.playingCard_black, .playingCard_black_opponent { color: black; }
.playingCard_red, .playingCard_red_opponent { color: red; }
.blankCard {
    display: inline-block;
    width: 60px;
    height: 90px;
    border: 1px solid #ccc;
    border-radius: 5px;
    margin: 5px;
    background-color: #eee;
    position: relative;
}
.foldedCard::after {
    content: '×';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 60px;
    color: rgba(255, 0, 0, 0.6);
    font-weight: normal;
}
.opponentCard {
    margin-bottom: 10px;
}
.menuButtons {
    margin-bottom: 5px;
    width: 100%;
}
</style>

<div id="mainContent" class="ui segment">
    <h2 class="ui header">Texas Hold 'em Poker</h2>
    <p>Welcome to Texas Hold 'em Poker! Host a game and give the code to friends so they can join and play.</p>
    <div class="ui center aligned basic segment">
        <button id="hostButton" class="ui large primary button">Host Game</button>
        <button id="joinButton" class="ui large secondary button">Join Game</button>
    </div>
</div>

<div id="gameDiv" style="display: none;">
    <div class="ui grid">
        <div class="four wide column">
            <div id="playerInformationCard" class="ui card fluid">
                <div class="content">
                    <div class="header" id="usernamesCards">My Cards</div>
                    <div class="description" id="mycards"></div>
                </div>
                <div class="extra content" id="selfMoneyArea">
                    <div id="usernamesMoney" style="font-size: 1.5em; font-weight: bold;"></div>
                    <div id="selfSpirituality" style="color: #6435c9; font-weight: bold;">Spirituality: 0</div>
                    <div id="blindStatus"></div>
                    <div id="status"></div>
                </div>
            </div>
            
            <div class="ui segment" id="skillArea" style="display: none;">
                <h4 class="ui dividing header">Skill</h4>
                <div id="skillName" style="font-weight: bold; margin-bottom: 5px;"></div>
                <div class="ui buttons fluid">
                    <button id="useSkillBtn" onclick="useSkill()" class="ui violet button">Use Skill</button>
                    <button id="skillInfoBtn" onclick="showSkillInfo()" class="ui button icon"><i class="info circle icon"></i></button>
                </div>
            </div>
            
            <div class="ui segment">
                <div id="playNext"></div>
                <button onClick="fold()" id="usernameFold" class="ui red button menuButtons" style="display:none;">Fold</button>
                <button onClick="check()" id="usernameCheck" class="ui button menuButtons" style="display:none;">Check</button>
                <button onClick="updateBetModal()" id="usernameBet" class="ui green button menuButtons" style="display:none;">Bet</button>
                <button onClick="call()" id="usernameCall" class="ui blue button menuButtons" style="display:none;">Call</button>
                <button onClick="updateRaiseModal()" id="usernameRaise" class="ui orange button menuButtons" style="display:none;">Raise</button>
                <button onClick="allIn()" id="usernameAllIn" class="ui purple button menuButtons" style="display:none;">All In</button>
                
                <button onClick="exitGame()" id="exitGameBtn" class="ui black fluid button" style="margin-top: 10px;">Exit Game</button>

                <h4 class="ui dividing header">Game Log</h4>
                <div id="gameLog" style="height: 250px; overflow-y: auto; font-family: monospace; font-size: 0.9em; padding: 5px; background: #f9f9f9; border: 1px solid #ddd;">
                </div>
            </div>
        </div>
        
        <div class="twelve wide column">
            <div class="ui segment">
                <h3 class="ui header" id="table-title"></h3>
                <div id="communityCards" class="ui basic segment center aligned"></div>
            </div>
            
            <div class="ui segment">
                <h4 class="ui dividing header">Opponents</h4>
                <div id="opponentCards" class="ui cards"></div>
            </div>
        </div>
    </div>
</div>

<!-- Modals -->
<div class="ui modal" id="hostModal">
    <div class="header">Host Game</div>
    <div class="content">
        <div id="hostModalContent">
            <p>Ready to start a game? Click the button below to get a room code.</p>
            <input type="hidden" id="hostName-field" value="<%= user.username %>">
            <button onclick="beginHost()" class="ui primary button">Get Code</button>
        </div>
        <div id="playersNames" class="ui list"></div>
        <div id="startGameArea" style="margin-top: 10px;"></div>
    </div>
    <div class="actions">
        <div class="ui cancel button">Close</div>
    </div>
</div>

<div class="ui modal" id="joinModal">
    <div class="header">Join Game</div>
    <div class="content">
        <div id="joinModalContent">
            <p>Enter the code provided by the host to join their room:</p>
            <div class="ui form">
                <input type="hidden" id="joinName-field" value="<%= user.username %>">
                <div class="field">
                    <label>Code</label>
                    <input type="text" id="code-field" placeholder="4-digit code">
                </div>
                <button onclick="joinRoom()" class="ui primary button">Join Game</button>
            </div>
        </div>
        <div id="playersNamesJoined" class="ui list"></div>
        <div id="startGameAreaDisconnectSituation" style="margin-top: 10px;"></div>
    </div>
    <div class="actions">
        <div class="ui cancel button">Close</div>
    </div>
</div>

<div class="ui modal" id="betModal">
    <div class="header">Place Bet</div>
    <div class="content">
        <div id="betDisplay"><h3 class="ui center aligned header">$0</h3></div>
        <div class="ui form">
            <div class="field">
                <label>Bet Amount</label>
                <div class="ui input">
                    <input type="number" id="betAmountInput" placeholder="Enter amount" oninput="validateBetInput()">
                </div>
                <p id="betRangeHint" style="margin-top: 5px; color: #666;"></p>
            </div>
        </div>
    </div>
    <div class="actions">
        <button id="confirmBetBtn" onclick="bet()" class="ui green button">Confirm Bet</button>
        <div class="ui cancel button">Cancel</div>
    </div>
</div>

<div class="ui modal" id="raiseModal">
    <div class="header">Raise Bet</div>
    <div class="content">
        <div id="raiseDisplay"><h3 class="ui center aligned header">Raise top bet</h3></div>
        <div class="ui form">
            <div class="field">
                <label>Total Amount to Raise To</label>
                <div class="ui input">
                    <input type="number" id="raiseAmountInput" placeholder="Enter amount" oninput="validateRaiseInput()">
                </div>
                <p id="raiseRangeHint" style="margin-top: 5px; color: #666;"></p>
            </div>
        </div>
    </div>
    <div class="actions">
        <button id="confirmRaiseBtn" onclick="raise()" class="ui orange button">Confirm Raise</button>
        <div class="ui cancel button">Cancel</div>
    </div>
</div>

<div class="ui modal" id="skillTargetModal">
    <div class="header">Select Target</div>
    <div class="content">
        <div id="skillTargetList" class="ui selection list"></div>
    </div>
    <div class="actions">
        <div class="ui cancel button">Cancel</div>
    </div>
</div>

<div class="ui modal" id="skillInfoModal">
    <div class="header">Skill Information</div>
    <div class="content" id="skillInfoContent"></div>
    <div class="actions">
        <div class="ui cancel button">Close</div>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
var socket = io('/poker_socket');
var currentUser = "<%= user.username %>";

$(document).ready(function () {
    $('#hostButton').click(function() { $('#hostModal').modal('show'); });
    $('#joinButton').click(function() { $('#joinModal').modal('show'); });
});

socket.on('playerDisconnected', function (data) {
    alert(data.player + ' disconnected.');
});

socket.on('hostRoom', function (data) {
    if (data != undefined) {
        let content = '<h5>Code: <code>' + data.code + '</code></h5>';
        if (data.players.length >= 11) content += '<p class="ui red text">Warning: Room is full (max 11).</p>';
        content += '<h5>Players Currently in My Room</h5>';
        $('#hostModalContent').html(content);
        $('#playersNames').html(data.players.map(p => '<div class="item">' + p + '</div>').join(''));
        
        if (data.players.length > 1) {
            $('#startGameArea').html('<button onclick="startGame(\'' + data.code + '\')" class="ui green fluid button">Start Game</button>');
        }
    } else {
        alert('Error hosting room.');
    }
});

socket.on('hostRoomUpdate', function (data) {
    $('#playersNames').html(data.players.map(p => '<div class="item">' + p + '</div>').join(''));
    if (data.players.length <= 1) $('#startGameArea').empty();
});

socket.on('joinRoom', function (data) {
    if (data == undefined) {
        $('#joinModal').modal('hide');
        alert("Invalid code or username already taken.");
    } else {
        $('#joinModalContent').html('<h5>' + data.host + "'s room</h5><hr /><p>Please wait until your host starts the game.</p>");
        $('#playersNamesJoined').html(data.players.map(p => '<div class="item">' + p + '</div>').join(''));
    }
});

socket.on('joinRoomUpdate', function (data) {
    $('#playersNamesJoined').html(data.players.map(p => '<div class="item">' + p + '</div>').join(''));
});

socket.on('gameBegin', function (data) {
    $('#joinModal').modal('hide');
    $('#hostModal').modal('hide');
    if (data == undefined) alert('Error - invalid game.');
    else {
        $('#mainContent').hide();
        $('#gameDiv').show();
    }
});

socket.on('dealt', function (data) {
    $('#mycards').html(data.cards.map(renderCard).join(''));
    $('#usernamesCards').text(data.username + ' - My Cards');
});

socket.on('rerender', function (data) {
    window.currentPlayers = data.players;
    window.currentMyBetInStage = data.myBet;
    window.isSmokeActive = data.topBet === '???';
    if (data.myBet == 0) $('#usernamesCards').text(data.username + ' - My Cards');
    else {
        let betText = window.isSmokeActive ? '???' : data.myBet;
        $('#usernamesCards').text(data.username + ' - My Bet: $' + betText);
    }
    
    if (data.community != undefined) $('#communityCards').html(data.community.map(renderCard).join(''));
    else $('#communityCards').empty();
    
    let turnPlayer = data.players.find(p => p.status === 'Their Turn');
    let turnText = turnPlayer ? (' | <span style="color: #21ba45;">Current Turn: ' + (turnPlayer.username === currentUser ? 'YOU' : turnPlayer.username) + '</span>') : '';
    $('#table-title').html('Round ' + data.round + ' | ' + data.stage + ' | Top Bet: $' + data.topBet + ' | Pot: $' + data.pot + turnText);
    
    // Sort players based on bet order in current stage
    let sortedPlayers = [...data.players];
    const currentStageBets = data.bets && data.bets.length > 0 ? data.bets[data.bets.length - 1] : [];
    
    if (currentStageBets.length > 0) {
        let bettorOrder = currentStageBets.map(b => b.player);
        sortedPlayers.sort((a, b) => {
            let indexA = bettorOrder.indexOf(a.username);
            let indexB = bettorOrder.indexOf(b.username);
            // Players who haven't bet yet go to the end
            if (indexA === -1 && indexB === -1) return 0;
            if (indexA === -1) return 1;
            if (indexB === -1) return -1;
            return indexA - indexB;
        });
    }

    $('#opponentCards').html(sortedPlayers.map(p => {
        return renderOpponent(p.username, p, data.bets);
    }).join(''));
    
    renderSelf({
        money: data.myMoney,
        text: data.myStatus,
        blind: data.myBlind,
        bets: data.bets,
        buyIns: data.buyIns,
        spirituality: data.mySpirituality,
        skill: data.mySkill,
        skillUsed: data.skillUsed,
        away: data.away,
        waiting: data.waiting
    });
    
    if (!data.roundInProgress) {
        $('.menuButtons').hide();
    }
});

socket.on('reveal', function (data) {
    $('.menuButtons').hide();
    $('#table-title').text('Hand Winner(s): ' + data.winners);
    $('#playNext').html('<button onClick="playNext()" class="ui fluid primary button">Start Next Round</button>');
    $('#blindStatus').text(data.hand);
    $('#usernamesMoney').text('$' + data.money);
    
    $('#opponentCards').html(data.cards.map(p => {
        return renderOpponentCards(p.username, p, data.bets);
    }).join(''));
});

socket.on('endHand', function (data) {
    $('.menuButtons').hide();
    $('#table-title').text(data.winner + ' takes the pot of $' + data.pot);
    $('#playNext').html('<button onClick="playNext()" class="ui fluid primary button">Start Next Round</button>');
    $('#usernamesMoney').text('$' + data.money);
    if (data.folded == 'Fold') {
        $('#status').text('You Folded');
        $('#playerInformationCard').addClass('secondary');
    }
});

socket.on('gameLog', function (data) {
    const logDiv = $('#gameLog');
    logDiv.append('<div>' + data.message + '</div>');
    logDiv.scrollTop(logDiv[0].scrollHeight);
});

// Game Actions
function beginHost() { socket.emit('host', { username: currentUser }); }
function joinRoom() { socket.emit('join', { code: $('#code-field').val(), username: currentUser }); }
function startGame(code) { socket.emit('startGame', { code: code }); }
function playNext() { socket.emit('startNextRound', {}); }
function fold() { socket.emit('moveMade', { move: 'fold', bet: 'Fold' }); }
function call() { socket.emit('moveMade', { move: 'call', bet: 'Call' }); }
function check() { socket.emit('moveMade', { move: 'check', bet: 'Check' }); }

const SKILL_DESCRIPTIONS = {
    'reveal': '<b>真理明牌 (Reveal Hand)</b><br>瞬间触发。向全场公开自己的两张底牌。用于心理压迫或建立信任。',
    'swap': '<b>虚空换牌 (Swap Card)</b><br>操作干预。从底牌中选一张由系统随机替换。换牌过程公开，结果私密。',
    'silence': '<b>灵魂沉默 (Silence)</b><br>规则锁定。使一名目标对手在下一轮行动中无法执行“加注(Raise)”。',
    'smoke': '<b>深渊烟雾弹 (Smoke Screen)</b><br>信息遮蔽。加注时触发，隐藏自己的下注和余额。本阶段后续跟注者的信息也将被遮蔽。',
    'fate': '<b>命运交换 (Exchange Fate)</b><br>因果重组。物理交换自己与一名目标对手的所有底牌。'
};

function showSkillInfo() {
    if (!window.currentSkill) return;
    let desc = SKILL_DESCRIPTIONS[window.currentSkill.id] || '暂无说明';
    $('#skillInfoContent').html(desc);
    $('#skillInfoModal').modal('show');
}

function useSkill() {
    if (!window.currentSkill) return;
    if (window.currentSkill.id === 'silence' || window.currentSkill.id === 'fate') {
        let targets = window.currentPlayers.filter(p => p.username !== currentUser && !p.waiting);
        if (targets.length === 0) return alert('No valid targets.');
        $('#skillTargetList').html(targets.map(p => 
            '<div class="item" onclick="confirmSkillTarget(\'' + p.username + '\')">' + p.username + '</div>'
        ).join(''));
        $('#skillTargetModal').modal('show');
    } else if (window.currentSkill.id === 'swap') {
        // Swap Card: User chooses which card to replace
        $('#skillTargetList').html([0, 1].map(idx => 
            '<div class="item" onclick="confirmSkillTarget(' + idx + ')">Card ' + (idx + 1) + '</div>'
        ).join(''));
        $('#skillTargetModal').modal('show');
    } else {
        if (confirm('Use ' + window.currentSkill.name + '?')) {
            socket.emit('useSkill', { target: null });
        }
    }
}

function confirmSkillTarget(target) {
    let targetDisplay = (typeof target === 'number') ? ('Card ' + (target + 1)) : target;
    if (confirm('Use ' + window.currentSkill.name + (target !== null ? ' on ' + targetDisplay : '') + '?')) {
        socket.emit('useSkill', { target: target });
        $('#skillTargetModal').modal('hide');
    }
}

function allIn() {
    let money = parseInt($('#usernamesMoney').text().replace('$', ''));
    if (money <= 0) return;
    
    // Determine if it's a bet or raise based on the current UI state
    // If Bet button is visible, it's an initial bet
    if ($('#usernameBet').is(':visible')) {
        socket.emit('moveMade', { move: 'bet', bet: money });
    } else {
        // Otherwise it's a raise to our total stack
        let myBetInStage = 0; // We'd need the actual bet in stage to calculate raise-to amount correctly
        // The server raise logic expects 'bet' to be the TOTAL amount in stage
        // We'll trust the server to handle the total amount
        socket.emit('moveMade', { move: 'raise', bet: money + (window.currentMyBetInStage || 0) });
    }
}

function exitGame() {
    if (confirm("Are you sure you want to exit? You will fold and leave the table.")) {
        socket.emit('playerExit', {});
        setTimeout(function() {
            window.location.reload();
        }, 500);
    }
}

var maxBetPossible = 0;
var minRaisePossible = 0;
var maxRaisePossible = 0;

function validateBetInput() {
    let val = parseInt($('#betAmountInput').val());
    let isValid = !isNaN(val) && val >= 2 && val <= maxBetPossible;
    $('#confirmBetBtn').toggleClass('disabled', !isValid);
    $('#betDisplay').html('<h3 class="ui center aligned header">' + (isValid && val == maxBetPossible ? 'All-In ' : '') + '$' + (isNaN(val) ? 0 : val) + '</h3>');
}

function validateRaiseInput() {
    let val = parseInt($('#raiseAmountInput').val());
    let isValid = !isNaN(val) && val >= minRaisePossible && val <= maxRaisePossible;
    $('#confirmRaiseBtn').toggleClass('disabled', !isValid);
    
    let displayVal = isNaN(val) ? 0 : val;
    let displayText = window.isSmokeActive ? ('Raise by $' + displayVal) : ('Raise top bet to $' + displayVal);
    $('#raiseDisplay').html('<h3 class="ui center aligned header">' + displayText + '</h3>');
}

function bet() {
    let val = parseInt($('#betAmountInput').val());
    if (isNaN(val) || val < 2 || val > maxBetPossible) return alert('Invalid bet amount.');
    socket.emit('moveMade', { move: 'bet', bet: val });
    $('#betModal').modal('hide');
}

function raise() {
    let val = parseInt($('#raiseAmountInput').val());
    if (isNaN(val) || val < minRaisePossible || val > maxRaisePossible) return alert('Invalid raise amount.');
    socket.emit('moveMade', { move: 'raise', bet: val });
    $('#raiseModal').modal('hide');
}

// Rendering helpers
function renderCard(card) {
    let color = (card.suit == '♠' || card.suit == '♣') ? 'black' : 'red';
    return '<div class="playingCard_' + color + '">' + card.value + ' ' + card.suit + '</div>';
}

function renderOpponent(name, p, bets) {
    let currentBet = 0;
    if (bets && bets.length) {
        let lastStage = bets[bets.length - 1];
        let found = lastStage.find(b => b.player === name);
        if (found) currentBet = found.bet;
    }
    
    let isFolded = (p.status === 'Fold');
    let color = (p.status === 'Their Turn') ? 'yellow' : (isFolded ? 'secondary' : (p.away ? 'secondary' : ''));
    let awayLabel = p.away ? ' <div class="ui mini gray label">AWAY</div>' : '';
    let waitingLabel = p.waiting ? ' <div class="ui mini blue label">WAITING</div>' : '';
    let dealerLabel = p.blind === 'Dealer' ? ' <div class="ui mini black label">D</div>' : '';
    let allInLabel = p.allIn ? ' <div class="ui mini red label">ALL-IN</div>' : '';
    let silenceLabel = p.isSilenced ? ' <div class="ui mini yellow label">SILENCED</div>' : '';
    let revealedLabel = p.revealed ? ' <div class="ui mini teal label">REVEALED</div>' : '';
    let skillUsedLabel = p.skillUsed ? ' <div class="ui mini violet label">SKILL USED</div>' : '';
    
    let cardContent = '';
    if (isFolded || p.waiting) {
        cardContent = '<div class="blankCard foldedCard"></div><div class="blankCard foldedCard"></div>';
    } else if (p.revealed && p.cards) {
        cardContent = p.cards.map(renderCard).join('');
    } else {
        cardContent = '<div class="blankCard"></div><div class="blankCard"></div>';
    }
    
    return '<div class="ui card ' + color + '">' +
           '<div class="content"><div class="header">' + name + (isFolded ? ' (Fold)' : '') + awayLabel + waitingLabel + dealerLabel + allInLabel + silenceLabel + revealedLabel + skillUsedLabel + '</div>' +
           '<div class="meta">' + (p.blind || '') + ' ' + (p.status || '') + ' | S: ' + p.spirituality + '</div>' +
           '<div class="description">' + cardContent + '</div></div>' +
           '<div class="extra content">' + (typeof p.money === 'number' ? '$' + p.money : p.money) + (currentBet > 0 ? ' | Bet: ' + (typeof currentBet === 'number' ? '$' + currentBet : currentBet) : '') + '</div></div>';
}

function renderOpponentCards(name, p, bets) {
    let currentBet = 0;
    if (bets && bets.length) {
        let lastStage = bets[bets.length - 1];
        let found = lastStage.find(b => b.player === name);
        if (found) currentBet = found.bet;
    }
    return '<div class="ui card">' +
           '<div class="content"><div class="header">' + name + '</div>' +
           '<div class="meta">' + (p.hand || '') + '</div>' +
           '<div class="description">' + (p.folded ? '<div class="blankCard"></div><div class="blankCard"></div>' : p.cards.map(renderCard).join('')) + '</div></div>' +
           '<div class="extra content">$' + p.money + (currentBet > 0 ? ' | Bet: $' + currentBet : '') + '</div></div>';
}

function renderSelf(data) {
    $('#playNext').empty();
    $('#usernamesMoney').text('$' + data.money);
    $('#selfSpirituality').text('Spirituality: ' + data.spirituality);
    
    if (data.skill && !data.skillUsed) {
        $('#skillArea').show();
        $('#skillName').text(data.skill.name + ' (Cost: ' + data.skill.cost + ')');
        window.currentSkill = data.skill;
    } else {
        $('#skillArea').hide();
    }

    $('#playerInformationCard').removeClass('yellow secondary green').css('border', '');
    
    if (data.away) {
        $('#playerInformationCard').addClass('secondary');
        $('#status').html('<div class="ui gray label">You are AWAY</div>');
        $('.menuButtons').hide();
    } else if (data.waiting) {
        $('#playerInformationCard').addClass('secondary');
        $('#status').html('<div class="ui blue label">Waiting for next round...</div>');
        $('.menuButtons').hide();
    } else if (data.text == 'Their Turn') {
        $('#playerInformationCard').addClass('yellow').css('border', '2px solid #fbbd08');
        $('#status').html('<div class="ui pointing red basic label">It\'s Your Turn!</div>');
        socket.emit('evaluatePossibleMoves', {});
    } else if (data.text == 'Fold') {
        $('#status').text('You Folded');
        $('#playerInformationCard').addClass('secondary');
        $('.menuButtons').hide();
    } else {
        $('#playerInformationCard').addClass('green');
        $('#status').empty();
        $('.menuButtons').hide();
    }
    $('#blindStatus').text(data.blind);
}

function updateBetModal() {
    let money = parseInt($('#usernamesMoney').text().replace('$', ''));
    maxBetPossible = money;
    $('#betAmountInput').val(2);
    $('#betRangeHint').text('Min: $2, Max: $' + money);
    validateBetInput();
    $('#betModal').modal('show');
}

function updateRaiseDisplay() {
    validateRaiseInput();
}

socket.on('updateRaiseModal', function (data) {
    minRaisePossible = data.topBet;
    maxRaisePossible = data.usernameMoney;
    
    if (window.isSmokeActive) {
        // Delta mode
        minRaisePossible = 1;
        // Max we can raise is limited by our money
        // Actually, if we're in smoke, the server handles the total.
        // We need to tell the user they can add up to (money) more.
        maxRaisePossible = data.usernameMoney - data.topBet; 
        if (maxRaisePossible < 0) maxRaisePossible = 0;
        
        $('#raiseAmountInput').val(1);
        $('#raiseRangeHint').text('Incremental Raise. Min: $1, Max: $' + maxRaisePossible);
    } else {
        $('#raiseAmountInput').val(data.topBet);
        $('#raiseRangeHint').text('Min: $' + data.topBet + ', Max: $' + data.usernameMoney);
    }
    
    validateRaiseInput();
    $('#raiseModal').modal('show');
});

function updateRaiseModal() { socket.emit('raiseModalData', {}); }

socket.on('displayPossibleMoves', function (data) {
    if (data.fold == 'yes') $('#usernameFold').show(); else $('#usernameFold').hide();
    if (data.check == 'yes') $('#usernameCheck').show(); else $('#usernameCheck').hide();
    if (data.bet == 'yes') $('#usernameBet').show(); else $('#usernameBet').hide();
    if (data.call != 'no') {
        let callText = 'Call';
        if (!data.isSmoke) {
            callText = (data.call == 'all-in' ? 'Call All-In' : 'Call $' + data.call);
        }
        $('#usernameCall').show().text(callText);
    } else $('#usernameCall').hide();
    if (data.raise == 'yes') $('#usernameRaise').show(); else $('#usernameRaise').hide();
    if (data.allIn == 'no') $('#usernameAllIn').hide(); else $('#usernameAllIn').show();
});
</script>

