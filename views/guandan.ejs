<% include header %>

<style>
#guandanGame {
  display: none;
}
.gd-layout {
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: 16px;
}
.gd-card {
  display: inline-flex;
  flex-direction: column;
  width: 54px;
  height: 78px;
  margin: 3px;
  padding: 6px;
  border: 1px solid #c9c9c9;
  border-radius: 6px;
  background: #fff;
  box-shadow: 0 1px 3px rgba(0,0,0,.12);
  cursor: pointer;
  user-select: none;
  vertical-align: top;
  font-weight: bold;
}
.gd-card-corner {
  display: flex;
  align-items: baseline;
  gap: 3px;
}
.gd-card.red {
  color: #db2828;
}
.gd-card.black {
  color: #1b1c1d;
}
.gd-card.joker {
  color: #6435c9;
}
.gd-card.selected {
  transform: translateY(-10px);
  border-color: #2185d0;
  box-shadow: 0 0 0 2px rgba(33,133,208,.2);
}
.gd-card.disabled {
  opacity: .35;
}
.gd-card-rank {
  font-size: 16px;
  line-height: 18px;
}
.gd-card-suit {
  font-size: 15px;
  line-height: 18px;
}
.gd-hand {
  min-height: 100px;
  padding: 10px;
  overflow-x: auto;
  overflow-y: hidden;
  white-space: nowrap;
}
.gd-stack {
  position: relative;
  display: inline-block;
  width: 60px;
  vertical-align: top;
  margin: 3px;
}
.gd-stack .gd-card {
  position: absolute;
  left: 0;
  margin: 0;
}
.gd-table {
  min-height: 180px;
}
.gd-log {
  height: 280px;
  overflow-y: auto;
  font-family: monospace;
  font-size: 12px;
  padding: 8px;
  background: #fafafa;
  border: 1px solid #ddd;
}
.gd-player.current {
  border-left: 4px solid #fbbd08;
}
.gd-player.self {
  background: #f8ffff;
}
@keyframes gd-urgent-pulse {
  0%, 100% {
    box-shadow: 0 0 var(--gd-glow-blur, 6px) 0 var(--gd-glow-color, #fbbd08);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 0 calc(var(--gd-glow-blur, 6px) * 2.2) calc(var(--gd-glow-blur, 6px) * .3) var(--gd-glow-color, #fbbd08);
    transform: scale(1.02);
  }
}
.gd-player.urgent {
  animation-name: gd-urgent-pulse;
  animation-iteration-count: infinite;
  animation-timing-function: ease-in-out;
  border-color: var(--gd-glow-color, #fbbd08) !important;
}
.gd-finish {
  min-height: 32px;
}
</style>

<div id="guandanLobby" class="ui segment">
  <h2 class="ui header">掼蛋</h2>
  <p>四人两两组队，按加入顺序落座：1/3 号一队，2/4 号一队。</p>
  <div class="ui center aligned basic segment">
    <button id="hostButton" class="ui large primary button">创建房间</button>
    <button id="joinButton" class="ui large secondary button">加入房间</button>
    <button id="spectateButton" class="ui large basic button">观战</button>
  </div>
</div>

<div id="guandanSpectate" style="display: none;">
  <div class="gd-layout">
    <div>
      <div class="ui segment">
        <h4 class="ui dividing header">观战中</h4>
        <div id="spectateRoomInfo" class="ui relaxed list"></div>
      </div>

      <div class="ui segment">
        <h4 class="ui dividing header">名次</h4>
        <div id="spectateFinishOrder" class="gd-finish"></div>
      </div>

      <div class="ui segment">
        <h4 class="ui dividing header">日志</h4>
        <div id="spectateLog" class="gd-log"></div>
      </div>
    </div>

    <div>
      <div class="ui segment">
        <h3 class="ui header" id="spectateTableTitle"></h3>
        <div class="ui two column stackable grid" id="spectatePlayersGrid"></div>
      </div>

      <div class="ui segment gd-table">
        <h4 class="ui dividing header">上一手</h4>
        <div id="spectateLastPlay"></div>
      </div>

      <div class="ui segment">
        <h4 class="ui dividing header" id="spectateHandTitle">点击左侧玩家查看手牌</h4>
        <div id="spectateHand" class="gd-hand"></div>
      </div>
    </div>
  </div>
  <div style="text-align: center; margin-top: 10px;">
    <button class="ui black button" onclick="exitSpectate()">离开观战</button>
  </div>
</div>

<div id="guandanGame">
  <div class="gd-layout">
    <div>
      <div class="ui segment">
        <h4 class="ui dividing header">牌局</h4>
        <div id="roomInfo" class="ui relaxed list"></div>
        <div id="phaseInfo" class="ui message"></div>
        <div id="actionArea" class="ui vertical fluid buttons"></div>
      </div>

      <div class="ui segment">
        <h4 class="ui dividing header">名次</h4>
        <div id="finishOrder" class="gd-finish"></div>
      </div>

      <div class="ui segment">
        <h4 class="ui dividing header">日志</h4>
        <div id="gameLog" class="gd-log"></div>
      </div>
    </div>

    <div>
      <div class="ui segment">
        <h3 class="ui header" id="tableTitle"></h3>
        <div class="ui two column stackable grid" id="playersGrid"></div>
      </div>

      <div class="ui segment gd-table">
        <h4 class="ui dividing header">上一手</h4>
        <div id="lastPlay"></div>
      </div>

      <div class="ui segment">
        <h4 class="ui dividing header">我的手牌</h4>
        <div id="myHand" class="gd-hand"></div>
      </div>
    </div>
  </div>
</div>

<div class="ui modal" id="hostModal">
  <div class="header">创建掼蛋房间</div>
  <div class="content">
    <div id="hostModalContent">
      <input type="hidden" id="hostName-field" value="<%= user.username %>">
      <button onclick="beginHost()" class="ui primary button">获取房间号</button>
    </div>
    <div id="hostPlayers" class="ui relaxed list"></div>
    <div id="startGameArea" style="margin-top: 10px;"></div>
  </div>
  <div class="actions">
    <div class="ui cancel button">关闭</div>
  </div>
</div>

<div class="ui modal" id="joinModal">
  <div class="header">加入掼蛋房间</div>
  <div class="content">
    <div id="joinModalContent">
      <input type="hidden" id="joinName-field" value="<%= user.username %>">
      <div class="ui form">
        <div class="field">
          <label>房间号</label>
          <input type="text" id="code-field" placeholder="4 位房间号">
        </div>
        <button onclick="joinRoom()" class="ui primary button">加入</button>
      </div>
    </div>
    <div id="joinPlayers" class="ui relaxed list"></div>
  </div>
  <div class="actions">
    <div class="ui cancel button">关闭</div>
  </div>
</div>

<div class="ui modal" id="spectateModal">
  <div class="header">观战</div>
  <div class="content">
    <div class="ui form">
      <div class="field">
        <label>房间号</label>
        <input type="text" id="spectate-code-field" placeholder="4 位房间号">
      </div>
      <button onclick="beginSpectate()" class="ui primary button">进入观战</button>
    </div>
  </div>
  <div class="actions">
    <div class="ui cancel button">关闭</div>
  </div>
</div>

<div class="ui modal" id="playChoiceModal">
  <div class="header">这几张牌有多种合法出法，请选择</div>
  <div class="content">
    <div id="playChoiceOptions" class="ui vertical fluid buttons"></div>
  </div>
  <div class="actions">
    <div class="ui cancel button">取消</div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
var socket = io('/guandan_socket');
var currentUser = "<%= user.username %>";
var currentState = null;
var selectedCards = new Set();
var hostedCode = null;
var handOrder = [];
var handOrderHandNumber = null;
var spectatorState = null;
var spectateSelectedSeat = null;

$(document).ready(function () {
  $('#hostButton').click(function() { $('#hostModal').modal('show'); });
  $('#joinButton').click(function() { $('#joinModal').modal('show'); });
  $('#spectateButton').click(function() { $('#spectateModal').modal('show'); });
});

function escapeHtml(text) {
  return String(text == null ? '' : text)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

function beginHost() {
  socket.emit('host', { username: currentUser });
}

function joinRoom() {
  socket.emit('join', { code: $('#code-field').val(), username: currentUser });
}

function beginSpectate() {
  socket.emit('spectate', { code: $('#spectate-code-field').val(), username: currentUser });
}

function exitSpectate() {
  socket.emit('spectatorExit', {});
  spectatorState = null;
  spectateSelectedSeat = null;
  $('#guandanSpectate').hide();
  $('#guandanLobby').show();
}

function startGame(code) {
  socket.emit('startGame', { code: code, username: currentUser });
}

function renderPlayersList(players) {
  return players.map(function(name, index) {
    return '<div class="item"><i class="user icon"></i><div class="content">' +
      escapeHtml(name) + ' <span class="ui mini label">座位 ' + (index + 1) + '</span>' +
      ' <span class="ui mini ' + (index % 2 === 0 ? 'blue' : 'green') + ' label">队伍 ' + (index % 2 + 1) + '</span></div></div>';
  }).join('');
}

function renderStartArea(data) {
  if (data.host === currentUser) {
    if (data.players.length === 4) {
      $('#startGameArea').html('<button onclick="startGame(\'' + data.code + '\')" class="ui green fluid button">开始游戏</button>');
    } else {
      $('#startGameArea').html('<div class="ui yellow message">需要 4 人才能开始。</div>');
    }
  }
}

socket.on('hostRoom', function (data) {
  if (!data) {
    alert('创建房间失败。');
    return;
  }
  hostedCode = data.code;
  $('#hostModalContent').html('<h5>房间号：<code>' + escapeHtml(data.code) + '</code></h5>');
  $('#hostPlayers').html(renderPlayersList(data.players));
  renderStartArea(data);
});

socket.on('joinRoom', function (data) {
  if (!data) {
    $('#joinModal').modal('hide');
    alert('房间不存在、已满或用户名重复。');
    return;
  }
  $('#joinModalContent').html('<h5>' + escapeHtml(data.host) + ' 的房间</h5><p>等待房主开始游戏。</p>');
  $('#joinPlayers').html(renderPlayersList(data.players));
});

socket.on('joinRoomUpdate', function (data) {
  $('#hostPlayers').html(renderPlayersList(data.players));
  $('#joinPlayers').html(renderPlayersList(data.players));
  renderStartArea(data);
});

socket.on('gameBegin', function (data) {
  $('#joinModal').modal('hide');
  $('#hostModal').modal('hide');
  if (!data) {
    alert('游戏启动失败。');
    return;
  }
  $('#guandanLobby').hide();
  $('#guandanGame').show();
});

socket.on('state', function (data) {
  currentState = data;
  pruneSelectedCards();
  $('#guandanLobby').hide();
  $('#guandanSpectate').hide();
  $('#guandanGame').show();
  renderState();
});

socket.on('spectateJoin', function (data) {
  if (!data) {
    alert('房间不存在。');
    return;
  }
  $('#spectateModal').modal('hide');
  $('#guandanLobby').hide();
  $('#guandanGame').hide();
  $('#guandanSpectate').show();
});

socket.on('spectateState', function (data) {
  spectatorState = data;
  renderSpectate();
});

socket.on('gameLog', function (data) {
  ['#gameLog', '#spectateLog'].forEach(function(sel) {
    var logDiv = $(sel);
    if (!logDiv.length) return;
    logDiv.append('<div>' + data.message + '</div>');
    logDiv.scrollTop(logDiv[0].scrollHeight);
  });
});

socket.on('actionError', function (data) {
  alert(data.message || '操作失败。');
});

var pendingPlayCardIds = null;

socket.on('playChoiceNeeded', function (data) {
  showPlayChoicePicker(data.options);
});

function showPlayChoicePicker(options) {
  var html = options.map(function(option, idx) {
    var desc = option.title + '（' + option.assignedRanks.map(escapeHtml).join(' ') + '）';
    return '<button class="ui button" onclick="choosePlayInterpretation(' + idx + ')">' + desc + '</button>';
  }).join('');
  $('#playChoiceOptions').html(html);
  $('#playChoiceModal').data('options', options).modal('show');
}

function choosePlayInterpretation(idx) {
  var options = $('#playChoiceModal').data('options');
  var option = options[idx];
  $('#playChoiceModal').modal('hide');
  socket.emit('playCards', {
    cardIds: pendingPlayCardIds,
    choice: { type: option.type, size: option.size, primary: option.primary },
  });
}

function phaseText(phase) {
  if (phase === 'lobby') return '等待开始';
  if (phase === 'tribute') return '进贡';
  if (phase === 'return') return '还贡';
  if (phase === 'playing') return '出牌';
  if (phase === 'handOver') return '本副结束';
  if (phase === 'gameOver') return '整局结束';
  return phase;
}

function renderState() {
  if (!currentState) return;
  $('#roomInfo').html(
    '<div class="item">房间：<code>' + escapeHtml(currentState.code) + '</code></div>' +
    '<div class="item">第 ' + currentState.handNumber + ' 副，级牌：<b>' + escapeHtml(currentState.currentLevel) + '</b></div>' +
    '<div class="item">队伍 1 等级：' + currentState.teamLevels[0] + '；队伍 2 等级：' + currentState.teamLevels[1] + '</div>'
  );
  var currentPlayerAway = false;
  if (currentState.currentTurn !== null) {
    var currentPlayerInfo = currentState.players.filter(function(p) { return p.seat === currentState.currentTurn; })[0];
    currentPlayerAway = !!(currentPlayerInfo && currentPlayerInfo.away);
  }
  $('#tableTitle').html('阶段：' + phaseText(currentState.phase) +
    (currentState.currentTurnName ? ' | 当前：<span style="color:#b58105">' + escapeHtml(currentState.currentTurnName) + '</span>' : '') +
    (currentPlayerAway ? ' <span class="ui small grey text">（已离线，超时后将自动处理）</span>' : ''));
  renderPhaseInfo();
  renderPlayers();
  renderLastPlay();
  renderFinishOrder();
  renderHand();
  renderActions();
}

function renderPhaseInfo() {
  var message = '';
  if (currentState.phase === 'tribute' && currentState.tribute) {
    message = '请选择一张最大可进贡牌给 ' + escapeHtml(currentState.tribute.to) + '。红心级牌不可进贡。';
  } else if (currentState.phase === 'return' && currentState.returnCard) {
    message = '请选择一张 2 到 10 的牌还给 ' + escapeHtml(currentState.returnCard.to) + '。';
  } else if (currentState.phase === 'playing' && currentState.canAct) {
    message = currentState.lastPlay ? '请选择能压过上一手的牌，或选择过牌。' : '你领出，可以出任意合法牌型。';
  } else if (currentState.phase === 'handOver') {
    message = '本副已结束，' + currentState.handOverReadyCount + '/' + currentState.handOverRequiredCount + ' 人已确认开始下一副。';
  } else if (currentState.phase === 'gameOver') {
    message = '整局已结束。';
  } else {
    message = '等待其他玩家操作。';
  }
  if (currentState.tributeResult) {
    message = '你进贡的 ' + escapeHtml(currentState.tributeResult.cardText) + ' 给了 ' +
      escapeHtml(currentState.tributeResult.toUsername) + '。' + (message ? ' ' + message : '');
  }
  $('#phaseInfo').text(message);
}

function urgentGlowColor(t) {
  // t in [0,1]: 0 = mild gold, 1 = intense red.
  var from = [251, 189, 8];
  var to = [219, 40, 40];
  var mix = from.map(function(c, i) { return Math.round(c + (to[i] - c) * t); });
  return 'rgb(' + mix.join(',') + ')';
}

function renderPlayers() {
  var URGENT_THRESHOLD = 10;
  var html = currentState.players.map(function(player) {
    var classes = 'ui segment gd-player';
    var style = '';
    if (player.isSelf) classes += ' self';
    if (currentState.currentTurn === player.seat) classes += ' current';
    if (!player.finishedRank && player.cardCount > 0 && player.cardCount <= URGENT_THRESHOLD) {
      var t = Math.min(1, (URGENT_THRESHOLD - player.cardCount + 1) / URGENT_THRESHOLD);
      var duration = (1.7 - t * 1.3).toFixed(2);
      classes += ' urgent';
      style = 'animation-duration:' + duration + 's; --gd-glow-color:' + urgentGlowColor(t) + '; --gd-glow-blur:' + Math.round(5 + t * 14) + 'px;';
    }
    var finish = player.finishedRank ? '<span class="ui red label">第 ' + player.finishedRank + ' 名</span>' : '';
    var away = player.away ? '<span class="ui gray label">离线</span>' : '';
    return '<div class="column"><div class="' + classes + '" style="' + style + '">' +
      '<h4 class="ui header">' + escapeHtml(player.username) + '</h4>' +
      '<p>座位 ' + (player.seat + 1) + ' | 队伍 ' + (player.team + 1) + '</p>' +
      '<p>剩余 ' + player.cardCount + ' 张 ' + finish + ' ' + away + '</p>' +
      '</div></div>';
  }).join('');
  $('#playersGrid').html(html);
}

function renderLastPlay() {
  if (!currentState.lastPlay) {
    $('#lastPlay').html('<div class="ui grey text">当前无人压牌。</div>');
    return;
  }
  $('#lastPlay').html(
    '<div><b>' + escapeHtml(currentState.lastPlay.username) + '</b>：' +
    escapeHtml(currentState.lastPlay.title) + '</div>' +
    '<div>' + currentState.lastPlay.cards.map(function(card) { return renderCard(card, false); }).join('') + '</div>'
  );
}

function renderFinishOrder() {
  if (!currentState.finishOrder.length) {
    $('#finishOrder').html('<span class="ui grey text">暂无</span>');
    return;
  }
  $('#finishOrder').html(currentState.finishOrder.map(function(item, index) {
    return '<div class="ui label">' + (index + 1) + '. ' + escapeHtml(item.username) + ' / 队伍 ' + (item.team + 1) + '</div>';
  }).join(' '));
}

function pruneSelectedCards() {
  if (currentState.handNumber !== handOrderHandNumber) {
    selectedCards.clear();
    return;
  }
  var validIds = {};
  currentState.self.hand.forEach(function(c) { validIds[c.id] = true; });
  Array.from(selectedCards).forEach(function(id) {
    if (!validIds[id]) selectedCards.delete(id);
  });
}

// handOrder is a list of "piles" (each an array of card ids) rendered as one
// stack. By default each pile is one rank. Moving a multi-card selection
// merges those cards into a single new pile at the target side.
function defaultPiles() {
  var byRank = {};
  var rankOrder = [];
  currentState.self.hand.forEach(function(c) {
    if (!byRank[c.rank]) { byRank[c.rank] = []; rankOrder.push(c.rank); }
    byRank[c.rank].push(c.id);
  });
  return rankOrder.map(function(r) { return byRank[r]; });
}

function syncHandOrder() {
  if (currentState.handNumber !== handOrderHandNumber) {
    handOrder = defaultPiles();
    handOrderHandNumber = currentState.handNumber;
    return;
  }
  var currentSet = {};
  currentState.self.hand.forEach(function(c) { currentSet[c.id] = true; });
  handOrder = handOrder
    .map(function(pile) { return pile.filter(function(id) { return currentSet[id]; }); })
    .filter(function(pile) { return pile.length > 0; });

  var known = {};
  handOrder.forEach(function(pile) { pile.forEach(function(id) { known[id] = true; }); });
  var newCards = currentState.self.hand.filter(function(c) { return !known[c.id]; });
  if (!newCards.length) return;

  // The server always sends self.hand pre-sorted by rank (level card highest,
  // 2 lowest). Use that as the ground truth for where a newly received card
  // (e.g. a tribute/return card mid-hand) should slot in, instead of just
  // dumping it at the end of the display order.
  var byId = {};
  currentState.self.hand.forEach(function(c) { byId[c.id] = c; });
  var canonicalRankIndex = {};
  currentState.self.hand.forEach(function(c, idx) {
    if (!(c.rank in canonicalRankIndex)) canonicalRankIndex[c.rank] = idx;
  });

  var newByRank = {};
  var newRankOrder = [];
  newCards.forEach(function(c) {
    if (!newByRank[c.rank]) { newByRank[c.rank] = []; newRankOrder.push(c.rank); }
    newByRank[c.rank].push(c.id);
  });

  newRankOrder.forEach(function(rank) {
    var mergeIndex = -1;
    for (var i = 0; i < handOrder.length; i++) {
      var pile = handOrder[i];
      if (pile.length && byId[pile[0]] && byId[pile[0]].rank === rank) {
        mergeIndex = i;
        break;
      }
    }
    if (mergeIndex !== -1) {
      handOrder[mergeIndex] = handOrder[mergeIndex].concat(newByRank[rank]);
      return;
    }

    var insertAt = handOrder.length;
    for (var j = 0; j < handOrder.length; j++) {
      var pileCard = byId[handOrder[j][0]];
      if (pileCard && canonicalRankIndex[pileCard.rank] > canonicalRankIndex[rank]) {
        insertAt = j;
        break;
      }
    }
    handOrder.splice(insertAt, 0, newByRank[rank]);
  });
}

function renderHand() {
  syncHandOrder();
  var byId = {};
  currentState.self.hand.forEach(function(c) { byId[c.id] = c; });
  $('#myHand').html(handOrder.map(function(pile) {
    var cards = pile.map(function(id) { return byId[id]; }).filter(Boolean);
    return renderStack(cards);
  }).join(''));
}

function renderStack(cards, selectable) {
  if (selectable === undefined) selectable = true;
  var STACK_OFFSET = 20;
  var height = 78 + Math.max(0, cards.length - 1) * STACK_OFFSET;
  var inner = cards.map(function(card, idx) {
    var style = 'top:' + (idx * STACK_OFFSET) + 'px; z-index:' + idx + ';';
    return renderCard(card, selectable, style);
  }).join('');
  return '<div class="gd-stack" style="height:' + height + 'px;">' + inner + '</div>';
}

function moveSelectedTo(direction) {
  var ids = selectedIds();
  if (!ids.length) return alert('请先选中要移动的牌。');
  var idSet = {};
  ids.forEach(function(id) { idSet[id] = true; });

  var moving = [];
  handOrder.forEach(function(pile) {
    pile.forEach(function(id) { if (idSet[id]) moving.push(id); });
  });

  var rest = handOrder
    .map(function(pile) { return pile.filter(function(id) { return !idSet[id]; }); })
    .filter(function(pile) { return pile.length > 0; });

  handOrder = direction === 'left' ? [moving].concat(rest) : rest.concat([moving]);
  selectedCards.clear();
  renderHand();
  renderActions();
}

function resetHandOrder() {
  if (!currentState) return;
  handOrder = defaultPiles();
  renderHand();
}

function cardColor(card) {
  if (card.joker) return 'joker';
  return (card.suit === 'H' || card.suit === 'D') ? 'red' : 'black';
}

function cardDisabled(card) {
  if (currentState.phase === 'tribute' && currentState.tribute) {
    return currentState.tribute.eligible.indexOf(card.id) === -1;
  }
  if (currentState.phase === 'return' && currentState.returnCard) {
    return currentState.returnCard.eligible.indexOf(card.id) === -1;
  }
  if (currentState.self.finishedRank) return true;
  return currentState.phase !== 'playing';
}

function renderCard(card, selectable, extraStyle) {
  var disabled = selectable && cardDisabled(card);
  var selected = selectedCards.has(card.id);
  var onclick = selectable && !disabled ? ' onclick="toggleCard(\'' + card.id + '\')"' : '';
  return '<div class="gd-card ' + cardColor(card) + (selected ? ' selected' : '') + (disabled ? ' disabled' : '') + '" style="' + (extraStyle || '') + '"' + onclick + '>' +
    '<div class="gd-card-corner">' +
    '<span class="gd-card-rank">' + escapeHtml(card.label) + '</span>' +
    '<span class="gd-card-suit">' + escapeHtml(card.suitLabel || '') + '</span>' +
    '</div>' +
    '</div>';
}

function toggleCard(cardId) {
  if (currentState.phase === 'tribute' || currentState.phase === 'return') {
    selectedCards.clear();
    selectedCards.add(cardId);
  } else if (selectedCards.has(cardId)) {
    selectedCards.delete(cardId);
  } else {
    selectedCards.add(cardId);
  }
  renderHand();
  renderActions();
}

function selectedIds() {
  return Array.from(selectedCards);
}

function renderActions() {
  var html = '';
  if (currentState.phase === 'tribute' && currentState.tribute) {
    html += '<button class="ui red button" onclick="selectTribute()">确认进贡</button>';
  } else if (currentState.phase === 'return' && currentState.returnCard) {
    html += '<button class="ui orange button" onclick="selectReturnCard()">确认还贡</button>';
  } else if (currentState.phase === 'playing' && currentState.canAct && !currentState.self.finishedRank) {
    html += '<button class="ui green button" onclick="playSelected()">出牌</button>';
    if (currentState.lastPlay) html += '<button class="ui button" onclick="passTurn()">过牌</button>';
  } else if (currentState.phase === 'handOver') {
    if (currentState.selfReadyForNextHand) {
      html += '<div class="ui disabled button">已确认，等待其他人（' + currentState.handOverReadyCount + '/' + currentState.handOverRequiredCount + '）</div>';
    } else {
      html += '<button class="ui primary button" onclick="startNextHand()">开始下一副</button>';
    }
  }
  if (currentState.phase === 'playing' && !currentState.self.finishedRank) {
    html += '<button class="ui basic button" onclick="moveSelectedTo(\'left\')">选中牌移到左侧</button>';
    html += '<button class="ui basic button" onclick="moveSelectedTo(\'right\')">选中牌移到右侧</button>';
  }
  if (currentState.self.hand.length) {
    html += '<button class="ui basic button" onclick="resetHandOrder()">还原手牌</button>';
  }
  html += '<button class="ui black button" onclick="exitGame()">离开</button>';
  $('#actionArea').html(html);
}

function playSelected() {
  pendingPlayCardIds = selectedIds();
  socket.emit('playCards', { cardIds: pendingPlayCardIds });
}

function passTurn() {
  socket.emit('pass', {});
}

function selectTribute() {
  var ids = selectedIds();
  if (ids.length !== 1) return alert('请选择一张进贡牌。');
  socket.emit('selectTribute', { cardId: ids[0] });
}

function selectReturnCard() {
  var ids = selectedIds();
  if (ids.length !== 1) return alert('请选择一张还贡牌。');
  socket.emit('selectReturn', { cardId: ids[0] });
}

function startNextHand() {
  socket.emit('startNextHand', {});
}

function exitGame() {
  if (confirm('确定离开当前房间吗？')) {
    socket.emit('playerExit', {});
    setTimeout(function() { window.location.reload(); }, 300);
  }
}

function renderSpectate() {
  if (!spectatorState) return;
  $('#spectateRoomInfo').html(
    '<div class="item">房间：<code>' + escapeHtml(spectatorState.code) + '</code></div>' +
    '<div class="item">第 ' + spectatorState.handNumber + ' 副，级牌：<b>' + escapeHtml(spectatorState.currentLevel) + '</b></div>' +
    '<div class="item">队伍 1 等级：' + spectatorState.teamLevels[0] + '；队伍 2 等级：' + spectatorState.teamLevels[1] + '</div>'
  );
  $('#spectateTableTitle').html('阶段：' + phaseText(spectatorState.phase) +
    (spectatorState.currentTurnName ? ' | 当前：<span style="color:#b58105">' + escapeHtml(spectatorState.currentTurnName) + '</span>' : ''));

  $('#spectatePlayersGrid').html(spectatorState.players.map(function(player) {
    var classes = 'ui segment gd-player';
    if (spectatorState.currentTurn === player.seat) classes += ' current';
    if (spectateSelectedSeat === player.seat) classes += ' self';
    var finish = player.finishedRank ? '<span class="ui red label">第 ' + player.finishedRank + ' 名</span>' : '';
    var away = player.away ? '<span class="ui gray label">离线</span>' : '';
    return '<div class="column"><div class="' + classes + '" style="cursor:pointer;" onclick="selectSpectatePlayer(' + player.seat + ')">' +
      '<h4 class="ui header">' + escapeHtml(player.username) + '</h4>' +
      '<p>座位 ' + (player.seat + 1) + ' | 队伍 ' + (player.team + 1) + '</p>' +
      '<p>剩余 ' + player.cardCount + ' 张 ' + finish + ' ' + away + '</p>' +
      '</div></div>';
  }).join(''));

  if (!spectatorState.lastPlay) {
    $('#spectateLastPlay').html('<div class="ui grey text">当前无人压牌。</div>');
  } else {
    $('#spectateLastPlay').html(
      '<div><b>' + escapeHtml(spectatorState.lastPlay.username) + '</b>：' +
      escapeHtml(spectatorState.lastPlay.title) + '</div>' +
      '<div>' + spectatorState.lastPlay.cards.map(function(card) { return renderCard(card, false); }).join('') + '</div>'
    );
  }

  if (!spectatorState.finishOrder.length) {
    $('#spectateFinishOrder').html('<span class="ui grey text">暂无</span>');
  } else {
    $('#spectateFinishOrder').html(spectatorState.finishOrder.map(function(item, index) {
      return '<div class="ui label">' + (index + 1) + '. ' + escapeHtml(item.username) + ' / 队伍 ' + (item.team + 1) + '</div>';
    }).join(' '));
  }

  renderSpectateHand();
}

function selectSpectatePlayer(seat) {
  spectateSelectedSeat = seat;
  renderSpectate();
}

function renderSpectateHand() {
  var player = spectatorState.players.filter(function(p) { return p.seat === spectateSelectedSeat; })[0];
  if (!player) {
    $('#spectateHandTitle').text('点击左侧玩家查看手牌');
    $('#spectateHand').html('');
    return;
  }
  $('#spectateHandTitle').text(escapeHtml(player.username) + ' 的手牌（' + player.hand.length + ' 张）');
  var groups = {};
  var order = [];
  (player.hand || []).forEach(function(c) {
    if (!groups[c.rank]) { groups[c.rank] = []; order.push(c.rank); }
    groups[c.rank].push(c);
  });
  $('#spectateHand').html(order.map(function(r) { return renderStack(groups[r], false); }).join(''));
}
</script>

